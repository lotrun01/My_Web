---
// About section component
---

<section id="about" class="section">
  <div class="container">
    <div class="about-content">
      <h2 class="gradient-text" data-i18n="about.title">Contenido del Canal</h2>
      <div class="about-grid">
        <div class="glass-card">
          <div class="card-icon">🎮</div>
          <h3 data-i18n="about.gaming.title">Gaming</h3>
          <p data-i18n="about.gaming.description">Gameplay, reviews y gameplays de los viejos y nuevos títulos. Desde acción hasta estrategia.</p>
        </div>
        <div class="glass-card">
          <div class="card-icon">💻</div>
          <h3 data-i18n="about.tech.title">Tecnología</h3>
          <p data-i18n="about.tech.description">Reviews de gadgets, tutoriales de programación y las últimas tendencias tech.</p>
        </div>
        <div class="glass-card">
          <div class="card-icon">🎬</div>
          <h3 data-i18n="about.creative.title">Contenido Creativo</h3>
          <p data-i18n="about.creative.description">Como hacer un modelo Vtuber, vlogs y contenido para la comunidad.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-content {
    text-align: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    margin-bottom: var(--spacing-3xl);
    font-size: var(--text-5xl);
  }

  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl);
    margin-top: var(--spacing-2xl);
  }

  .glass-card {
    text-align: center;
  }

  .card-icon {
    font-size: 4rem;
    margin-bottom: var(--spacing-md);
    filter: drop-shadow(0 0 20px rgba(99, 102, 241, 0.5));
  }

  .glass-card h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--spacing-md);
    color: var(--color-text-primary);
  }

  .glass-card p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: var(--text-4xl);
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>
