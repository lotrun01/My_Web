---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<section id="projects" class="section">
  <div class="container">
    <h2 class="section-title gradient-text" data-i18n="projects.title">Personal Games Reviews</h2>
    <div class="projects-grid">
      {sortedProjects.map((project) => (
        <article class="project-card glass-card">
          {project.data.image && (
            <div class="project-image">
              <img src={project.data.image} alt={project.data.title} loading="lazy" />
              {project.data.score !== undefined && (
                <div class={`project-score ${project.data.score > 5 ? 'score-high' : 'score-low'}`}>
                  {project.data.score}
                </div>
              )}
            </div>
          )}
          <div class="project-content">
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-description">{project.data.description}</p>
            <div class="project-tags">
              {project.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            {project.data.link && (
              <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="project-link">
                Trailer →
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-title {
    text-align: center;
    font-size: var(--text-4xl);
    margin-bottom: var(--spacing-2xl);
  }

  .projects-grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--spacing-xl) * 2)) / 3);
    gap: var(--spacing-xl);
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: var(--spacing-lg);
    scroll-snap-type: x mandatory;
  }

  /* Scrollbar personalizado para el recuadro horizontal */
  .projects-grid::-webkit-scrollbar {
    height: 8px;
  }
  .projects-grid::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
  }
  .projects-grid::-webkit-scrollbar-thumb {
    background: var(--color-accent-primary, rgba(255, 255, 255, 0.2));
    border-radius: 4px;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-auto-columns: calc((100% - var(--spacing-xl)) / 2);
    }
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-auto-columns: 100%;
    }
  }

  .project-card {
    transition: transform 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
  }

  .project-card:hover {
    transform: translateY(-5px);
  }

  .project-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    position: relative;
    border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-score {
    position: absolute;
    top: var(--spacing-sm, 12px);
    right: var(--spacing-sm, 12px);
    font-size: 2rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    background: rgba(0, 0, 0, 0.75);
    border-radius: var(--border-radius-lg);
    backdrop-filter: blur(4px);
    border: 2px solid;
    z-index: 2;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-score {
    transform: scale(1.1);
  }

  .score-high {
    color: #4ade80;
    border-color: #4ade80;
  }

  .score-low {
    color: #ef4444;
    border-color: #ef4444;
  }

  .project-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--spacing-lg);
  }

  .project-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .project-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
    flex-grow: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
  }

  .tag {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-accent-primary);
  }

  .project-link {
    display: inline-block;
    color: var(--color-accent-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .project-link:hover {
    color: var(--color-accent-primary);
  }
</style>
