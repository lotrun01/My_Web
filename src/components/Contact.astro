---
// Contact section component
---

<section id="contact" class="section">
  <div class="container">
    <div class="contact-content">
      <h2 class="gradient-text" data-i18n="contact.title">Únete a la Comunidad</h2>
      <p class="contact-subtitle" data-i18n="contact.subtitle">
        Sígueme en todas las plataformas y no te pierdas ningún contenido
      </p>
      <div class="contact-grid">
        <div class="glass-card contact-card">
          <div class="contact-icon">📺</div>
          <h3 data-i18n="contact.youtube">Videos</h3>
          <div class="social-links">
            <a href="https://www.tiktok.com/@lotrun01" class="social-link">TikTok</a>            
            <a href="https://rumble.com/user/Lotrun" class="social-link">Rumble</a>
            <a href="https://www.youtube.com/@Lotrun01" class="social-link">Youtube</a>
          </div>
        </div>
        <div class="glass-card contact-card">
          <div class="contact-icon">🎮</div>
          <h3 data-i18n="contact.socialNetworks">Redes Sociales</h3>
          <div class="social-links">
            <a href="https://discord.com/users/1152739775200108648" class="social-link">Discord</a>
            <a href="https://www.twitch.tv/lotrun01" class="social-link">Twitch</a>
            <a href="https://steamcommunity.com/profiles/76561198071040962/" class="social-link">Steam</a>
            <a href="https://kick.com/lotrun" class="social-link">Kick</a>                  
            <a href="https://x.com/Lotrun01" class="social-link">X</a>
          </div>
        </div>
        <div class="glass-card contact-card">
          <div class="contact-icon">💬</div>
          <h3 data-i18n="contact.contactLabel">Contacto</h3>
          <p>lotrun01@gmail.com</p>
        </div>
      </div>
      <div class="cta-section">
        <button onclick="window.location.href='https://www.youtube.com/@Lotrun01'" class="btn btn-primary btn-large" data-i18n="contact.subscribeNow">Suscribirse Ahora</button>
      </div>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <p>&copy; 2026 LOTRUN. <span data-i18n="contact.footer">Creador de Contenido · Gaming & Tech</span></p>
  </div>
</footer>

<style>
  .contact-content {
    text-align: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    margin-bottom: var(--spacing-md);
    font-size: var(--text-5xl);
  }

  .contact-subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-3xl);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-3xl);
  }

  .contact-card {
    text-align: center;
  }

  .contact-icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
    filter: drop-shadow(0 0 20px rgba(139, 92, 246, 0.5));
  }

  .contact-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--spacing-sm);
  }

  .contact-card p {
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .social-links {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .social-link {
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    transition: all var(--transition-base);
    font-size: var(--text-sm);
  }

  .social-link:hover {
    background: rgba(99, 102, 241, 0.2);
    border-color: var(--color-accent-primary);
    transform: translateY(-2px);
  }

  .cta-section {
    margin-top: var(--spacing-3xl);
  }

  .btn-large {
    padding: var(--spacing-md) var(--spacing-2xl);
    font-size: var(--text-lg);
  }

  .footer {
    padding: var(--spacing-2xl) 0;
    text-align: center;
    border-top: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
  }

  .footer p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: var(--text-4xl);
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .btn-large {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
