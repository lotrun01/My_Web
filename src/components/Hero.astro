---
// Hero section component
---

<section id="hero" class="section">
  <div class="container">
    <div class="hero-content">
      <div class="avatar-container fade-in">
        <img src={`${import.meta.env.BASE_URL}lotrun-avatar.png`} alt="LOTRUN Avatar" class="avatar" />
      </div>
      <h1 class="gradient-text fade-in">LOTRUN</h1>
      <p class="hero-subtitle fade-in" data-i18n="hero.tagline">
        Gaming · Tecnología · Contenido Creativo
      </p>
      <div class="hero-buttons fade-in">
        <a href="https://www.youtube.com/@Lotrun01" class="btn btn-primary" data-i18n="hero.watchVideos">Ver Videos</a>
        <a href="https://www.twitch.tv/lotrun01" class="btn btn-secondary" data-i18n="hero.subscribe">Suscribirse</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-content {
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-3xl) 0;
  }

  .avatar-container {
    margin-bottom: var(--spacing-xl);
  }

  .avatar {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 4px solid var(--color-accent-primary);
    box-shadow: 0 0 40px rgba(0, 255, 0, 0.5), 0 0 80px rgba(0, 255, 0, 0.3);
    animation: float 6s ease-in-out infinite;
    object-fit: cover;
  }

  h1 {
    font-size: var(--text-7xl);
    margin-bottom: var(--spacing-lg);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: var(--text-2xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero-buttons {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .avatar {
      width: 150px;
      height: 150px;
    }

    h1 {
      font-size: var(--text-5xl);
    }

    .hero-subtitle {
      font-size: var(--text-lg);
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
